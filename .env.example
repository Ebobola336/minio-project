#!/usr/bin/env dotenv
# @file .env.example
# @brief Шаблон переменных окружения для MinIO инфраструктуры.
# @author Тимошенко (заполнить ФИО)
# @date 2025-05-25
# @version 1.0.0
# @license GNU GPLv3

# ==============================================================================
# НАСТРОЙКИ MINIO
# ==============================================================================
MINIO_ROOT_USER=minioadmin
# ВНИМАНИЕ: Пароль хранится в secrets/minio_root_password.txt (Docker Secret)
MINIO_CONSOLE_URL=https://localhost:9443

# ==============================================================================
# НАСТРОЙКИ NGINX
# ==============================================================================
NGINX_HOST=localhost
NGINX_S3_PORT=9000
NGINX_CONSOLE_PORT=9443

# ==============================================================================
# НАСТРОЙКИ GRAFANA
# ==============================================================================
GRAFANA_ADMIN_USER=admin
# ВНИМАНИЕ: Пароль хранится в secrets/grafana_admin_password.txt (Docker Secret)

# ==============================================================================
# НАСТРОЙКИ PROMETHEUS
# ==============================================================================
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION_TIME=15d

# ==============================================================================
# СРЕДА ВЫПОЛНЕНИЯ
# ==============================================================================
# Допустимые значения: development, staging, production
APP_ENV=development
APP_DEBUG=true
